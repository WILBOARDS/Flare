{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API (NestJS)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/.bin/nest", "start", "--watch"],
      "port": 3001,
      "cwd": "apps/api"
    },
    {
      "name": "Web (Next.js)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/.bin/next", "dev", "--port", "3000"],
      "port": 3000,
      "cwd": "apps/web"
    }
  ]
}
