{
  "name": "flare",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@flare/web",
    "dev:api": "turbo run dev --filter=@flare/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:up": "docker compose -f docker/docker-compose.yml up -d",
    "db:down": "docker compose -f docker/docker-compose.yml down",
    "contracts:compile": "turbo run build --filter=@flare/contracts",
    "contracts:test": "pnpm --filter @flare/contracts test",
    "contracts:deploy": "pnpm --filter @flare/contracts run deploy"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "prettier": "^3.2.0"
  },
  "packageManager": "pnpm@9.1.0"
}
